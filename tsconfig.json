{
	"files": [],
	"references": [{ "path": "./tsconfig.node.json" }, { "path": "./tsconfig.cloudflare.json" }],
	"compilerOptions": {
		"checkJs": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"resolveJsonModule": true,
		"plugins": [
			{
				"name": "gql.tada/ts-plugin",
				"schema": "https://readonlydemo.vendure.io/shop-api",
				"tadaOutputLocation": "./app/graphql/graphql-env.d.ts"
			}
		],
		"types": ["@cloudflare/workers-types"],
		"baseUrl": ".",
		"paths": {
			"~/*": ["./app/*"]
		}
	}
}
